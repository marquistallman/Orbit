# Frontend Environment Configuration

# Auth Service API (for authentication)
# Note: When running with Docker Compose, this should point to http://auth-service:8080
VITE_API_URL=http://localhost:8080/api

# IA Service API (for AI agent integration)
# Note: When running with Docker Compose, this should point to http://ia-service:5000
VITE_IA_SERVICE_URL=http://localhost:5000
