# Database Credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT Secret
JWT_SECRET=change-me

# IA Service / OpenRouter
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:12000
OPENROUTER_APP_NAME=Orbit
CORS_ALLOWED_ORIGINS=http://localhost:12000
CORS_ALLOW_CREDENTIALS=true
HTTP_TIMEOUT_SECONDS=20
MEMORY_DB_PATH=/data/agent_memory.db
USAGE_DB_PATH=/data/usage.db
DEFAULT_PLAN=free
ALLOW_ANONYMOUS_USER=true
PLAN_ADMIN_API_KEY=change-me-plan-admin-key

# Plan enforcement and cost optimization
PLAN_FREE_RATE_PER_MIN=30
PLAN_LITE_RATE_PER_MIN=60
PLAN_STANDARD_RATE_PER_MIN=120
PLAN_PRO_RATE_PER_MIN=240
PLAN_FREE_RESTRICTED_TOOLS=code_run,mini_maps
PLAN_LITE_RESTRICTED_TOOLS=
PLAN_STANDARD_RESTRICTED_TOOLS=
PLAN_PRO_RESTRICTED_TOOLS=
PLAN_DEGRADE_WARN_THRESHOLD=0.80
PLAN_DEGRADE_HARD_THRESHOLD=0.90
PLAN_DEGRADE_WARN_MAX_OUTPUT_CHARS=3000
PLAN_DEGRADE_HARD_MAX_OUTPUT_CHARS=1800
OPENROUTER_MODEL_CHEAP=openai/gpt-4o-mini

# Internal Service URLs
GMAIL_SERVICE_URL=http://gmail-service:8082
TOKEN_VAULT_URL=http://auth-service:8080
DOC_SERVICE_URL=http://doc-service:9002
CODE_SERVICE_URL=http://code-service:9003
EXCEL_SERVICE_URL=http://excel-service:9004
MINI_MAPS_SERVICE_URL=http://mini-maps-service:9005

# Code Service Security
CODE_EXEC_TIMEOUT_SECONDS=5
CODE_MAX_CHARS=12000
CODE_MAX_OUTPUT_CHARS=4000
CODE_MAX_MEMORY_MB=128
CODE_MAX_STDIN_CHARS=4000
CODE_MAX_SQL_RESULT_ROWS=200
CODE_MAX_SQL_STATEMENTS=30
CODE_STRICT_MODE=true
CODE_PYTHON_ALLOWED_IMPORTS=math,statistics,decimal,datetime,time,json,csv,sqlite3,collections,itertools,functools,fractions,random,re,typing,pathlib,openpyxl
CODE_JS_ALLOWED_MODULES=
CODE_PYTHON_BLOCK_PATTERNS=
CODE_JS_BLOCK_PATTERNS=
CODE_SQL_BLOCK_PATTERNS=
CODE_SNIPPETS_DB_PATH=/data/snippets.db

# Integrations - Delivery Apps
CONNECTOR_DELIVERY_ENABLED=false
DELIVERY_API_URL=
DELIVERY_API_KEY=

# Integrations - Messaging (WhatsApp / Telegram)
CONNECTOR_WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Telegram MTProto (personal account access — obtain from https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_DB_PATH=/data/telegram_sessions.db

# Integrations - Reservations
CONNECTOR_RESERVATIONS_ENABLED=false
RESERVATIONS_API_URL=
RESERVATIONS_API_KEY=

# Integrations - Public Transport
CONNECTOR_TRANSPORT_ENABLED=false
PUBLIC_TRANSPORT_API_URL=
PUBLIC_TRANSPORT_API_KEY=

# Integrations - Brokers
CONNECTOR_BROKER_ENABLED=false
BROKER_API_URL=
BROKER_API_KEY=
BROKER_API_SECRET=

# Integrations - Banking
CONNECTOR_BANK_ENABLED=false
BANK_API_URL=
BANK_API_KEY=
BANK_API_SECRET=

# OAuth2 Credentials
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
GITHUB_CLIENT_ID=placeholder
GITHUB_CLIENT_SECRET=placeholder
FACEBOOK_CLIENT_ID=placeholder
FACEBOOK_CLIENT_SECRET=placeholder
LINKEDIN_CLIENT_ID=placeholder
LINKEDIN_CLIENT_SECRET=placeholder

# Frontend public URLs (used as Vite build args — set to your domain in production)
VITE_API_URL=http://localhost:12001
VITE_IA_URL=http://localhost:12002
VITE_MINI_MAPS_URL=http://localhost:12007

# Application URLs (used by auth-service for OAuth redirects and CORS)
APP_FRONTEND_URL=http://localhost:12000
CORS_ALLOWED_ORIGINS=http://localhost:12000

# Observability
GRAFANA_ADMIN_PASSWORD=change-me-in-production

# Spring JPA (set to 'validate' in production after running migrations)
SPRING_JPA_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
